{
  "name": "nash81/bsicards-php-sdk",
  "description": "PHP SDK for BSICARDS - Card Issuance API",
  "type": "library",
  "version": "1.0.0",
  "license": "MIT",
  "keywords": [
    "bsicards",
    "card-issuance",
    "mastercard",
    "visa",
    "digital-wallet",
    "api",
    "sdk"
  ],
  "authors": [
    {
      "name": "BSI Group",
      "email": "support@bsigroup.tech"
    }
  ],
  "require": {
    "php": ">=7.4",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "phpstan/phpstan": "^1.8"
  },
  "autoload": {
    "psr-4": {
      "BSICards\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BSICards\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit tests/",
    "test-coverage": "phpunit --coverage-html build/coverage tests/",
    "analyse": "phpstan analyse src tests"
  }
}

